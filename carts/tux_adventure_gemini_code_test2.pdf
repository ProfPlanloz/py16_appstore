 {"name": "", "data": null, "format": null, "base_note": 24}, {"name": "", "data": null, "format": null, "base_note": 24}, {"name": "", "data": null, "format": null, "base_note": 24}, {"name": "", "data": null, "format": null, "base_note": 24}, {"name": "", "data": null, "format": null, "base_note": 24}, {"name": "", "data": null, "format": null, "base_note": 24}, {"name": "", "data": null, "format": null, "base_note": 24}, {"name": "", "data": null, "format": null, "base_note": 24}], "code": "import py16\nimport random \n\n# @manual\n# @description\n# DE: Ein episches Jump & Run Abenteuer! Rette deine Freundin Penny vor dem Lava-Gnom. Reise ueber die Weltkarte und durchquere vier gefaehrliche Level!\n# EN: An epic Jump & Run adventure! Save your girlfriend Penny from the Lava Gnome. Travel across the world map and conquer four dangerous levels!\n#\n# @controls\n# DEUTSCH:\n# Pfeiltasten : Bewegen / Weltkarte steuern\n# Z           : Springen / Level betreten\n# X           : Pause / Zurueck\n# Enter       : Bestaetigen / Im Menue navigieren\n#\n# ENGLISH:\n# Arrow Keys  : Move / Steer on World Map\n# Z           : Jump / Enter Level\n# X           : Pause / Back\n# Enter       : Confirm / Navigate Menu\n#\n# @credits\n# Code, Art & Game Design: Gemini pro 3.1\n# Engine: py-16 Fantasy Console\n# @end\n\n# --- Lokalisierung (\u00dcbersetzungen) ---\nlang = \"DE\" \n\nT = {\n    \"DE\": {\n        \"start\": \"STARTEN\", \"highscore\": \"HIGHSCORE\",\n        \"sound_on\": \"SOUND: AN\", \"sound_off\": \"SOUND: AUS\",\n        \"lang\": \"SPRACHE: DEUTSCH\", \"best_scores\": \"BESTE LEISTUNGEN\",\n        \"record\": \"REKORD: \", \"press_enter\": \"DRUECKE ENTER\",\n        \"for_back\": \"FUER ZURUECK\", \"level1\": \"LEVEL 1 - DRUECKE Z ZUM STARTEN\",\n        \"level2\": \"LEVEL 2 (WASSER) - DRUECKE Z\", \"level3\": \"LEVEL 3 (GEBIRGE) - DRUECKE Z\",\n        \"level4\": \"LEVEL 4 (VULKAN) - FINALE!\", \"map_move\": \"WELTKARTE - PFEILTASTEN ZUM BEWEGEN\",\n        \"back\": \"[X] ZURUECK\", \"pause\": \"PAUSE\", \"resume\": \"[X] WEITER\",\n        \"map_btn\": \"[ENTER] MAP\", \"goal\": \"ZIEL ERREICHT!\", \"score\": \"SCORE: \",\n        \"enter_map\": \"ENTER ZUR MAP\", \"game_clear1\": \"SPIEL DURCHGESPIELT!\",\n        \"game_clear2\": \"DU BIST EIN HELD!\", \"thanks1\": \"DANKE, DASS DU MICH\",\n        \"thanks2\": \"GERETTET HAST!\"\n    },\n    \"EN\": {\n        \"start\": \"START GAME\", \"highscore\": \"HIGHSCORE\",\n        \"sound_on\": \"SOUND: ON\", \"sound_off\": \"SOUND: OFF\",\n        \"lang\": \"LANGUAGE: ENGLISH\", \"best_scores\": \"BEST SCORES\",\n        \"record\": \"RECORD: \", \"press_enter\": \"PRESS ENTER\",\n        \"for_back\": \"TO RETURN\", \"level1\": \"LEVEL 1 - PRESS Z TO START\",\n        \"level2\": \"LEVEL 2 (WATER) - PRESS Z\", \"level3\": \"LEVEL 3 (MOUNTAIN) - PRESS Z\",\n        \"level4\": \"LEVEL 4 (VOLCANO) - FINALE!\", \"map_move\": \"WORLD MAP - ARROW KEYS TO MOVE\",\n        \"back\": \"[X] BACK\", \"pause\": \"PAUSED\", \"resume\": \"[X] RESUME\",\n        \"map_btn\": \"[ENTER] MAP\", \"goal\": \"LEVEL CLEARED!\", \"score\": \"SCORE: \",\n        \"enter_map\": \"ENTER TO MAP\", \"game_clear1\": \"GAME COMPLETED!\",\n        \"game_clear2\": \"YOU ARE A HERO!\", \"thanks1\": \"THANK YOU FOR\",\n        \"thanks2\": \"RESCUING ME!\"\n    }\n}\n\n# --- Zustands-Management ---\ngame_state = \"MENU\" # MENU, OVERWORLD, PLAYING, HIGHSCORE, PAUSED, ENDING, DYING\nmenu_index = 0 \nhigh_score = 0\nsound_on = True \n\nlevel1_completed = False\nlevel2_completed = False\nlevel3_completed = False\ncurrent_level = 1\n\nearthquake_timer = 0\nis_earthquake = False\n\n# --- Mode 7 Overworld Status ---\now_x, ow_y = 516.0, 488.0  \now_angle = -1.57           \now_speed = 2.0\n\n# --- Spiellogik & Status (Platformer) ---\npx, py = 16, 64\nvx, vy = 0.0, 0.0\non_ground = False\nfacing_right = True\nwalk_timer = 0\n\n# --- NEU: Kamera-Variablen f\u00fcr weiche Verfolgung ---\ncam_x, cam_y = 0.0, 0.0\n\nGRAVITY = 0.2\nJUMP_FORCE = -4.8 \nSPEED = 2.0\n\nLEVEL_WIDTH_TILES = 128 \nLEVEL_HEIGHT_TILES = 32\nTILE_SIZE = 8\n\ngoal_x, goal_y = 0, 0 \ngoal_reached = False\n\nscore = 0\ncoins = [] \nenemies = []     \nprojectiles = [] \nmoving_platforms = [] \nfloating_texts = [] # NEU: Aufsteigende Texte\n\now_clouds = []\nbg_objects = []\n\n# --- BOSS & ENDING STATUS ---\nboss = {}\nboss_death_timer = 0\nending_timer = 0\n\nbgm_melody = [261, 329, 392, 523, 392, 329, 261, 392, 293, 349, 440, 587, 440, 349, 293, 440]\nboss_melody = [130, 146, 130, 164, 130, 146, 123, 110] \ndeath_melody = [200, 180, 160, 140, 100] # Traurige Melodie\n\ndef get_level_width_pixels():\n    if current_level == 4: return 256 \n    return LEVEL_WIDTH_TILES * TILE_SIZE\n\ndef play_tone(pitch, duration, wave, channel=-1):\n    if sound_on: py16.tone(pitch, duration, wave, channel=channel)\n\ndef spawn_float_text(x, y, text, color=11):\n    \"\"\"Spawnt einen schwebenden Text (z.B. +10 Punkte)\"\"\"\n    floating_texts.append({\"x\": x, \"y\": y, \"text\": text, \"timer\": 40, \"color\": color})\n\ndef kill_player():\n    \"\"\"Startet die Todesanimation\"\"\"\n    global game_state, vy\n    if game_state == \"DYING\": return\n    game_state = \"DYING\"\n    vy = -4.0 # H\u00fcpft traurig in die Luft\n    py16.burst_explosion(px + 4, py + 4, color=8)\n    for i, pitch in enumerate(death_melody):\n        # Spielt die Melodie verz\u00f6gert ab\n        if sound_on: py16.tone(pitch, 150, py16.WAVE_SQUARE, channel=5)\n\ndef init():\n    for y in range(8):\n        for x in range(8):\n            py16.sset(8 + x, y, 11)   \n            py16.sset(16 + x, y, 4)   \n            py16.sset(32 + x, y, 3)   \n            py16.sset(40 + x, y, 1)   \n            py16.sset(48 + x, y, 8)   \n            py16.sset(56 + x, y, 4)   \n            py16.sset(64 + x, y, 12)  \n            py16.sset(72 + x, y, 15)  \n            py16.sset(80 + x, y, 2)   \n            py16.sset(88 + x, y, 5)   \n            py16.sset(96 + x, y, 10)  \n            py16.sset(104 + x, y, 6)  \n            py16.sset(112 + x, y, 5)  \n            py16.sset(120 + x, y, 9)  \n            py16.sset(128 + x, y, 4)  \n            \n    for x in range(8): py16.sset(24 + x, 7, 5) \n    py16.sset(25, 6, 6); py16.sset(25, 5, 6) \n    py16.sset(28, 6, 6); py16.sset(28, 5, 6) \n    py16.sset(31, 6, 6); py16.sset(31, 5, 6) \n    \n    for y in range(2, 6):\n        for x in range(2, 6):\n            py16.sset(48 + x, y, 10) \n            py16.sset(64 + x, y, 10) \n            py16.sset(96 + x, y, 7) \n            py16.sset(136 + x, y, 0) \n            \n    py16.sset(136, 0, 8); py16.sset(137, 0, 8); py16.sset(138, 0, 8) \n            \n    py16.sset(56, 2, 0); py16.sset(63, 5, 0); py16.sset(58, 7, 0)\n    py16.sset(41, 2, 12); py16.sset(43, 3, 12); py16.sset(45, 5, 12)\n\n    for cx in range(128):\n        for cy in range(128): py16.mset(cx, cy, 5, layer=2)\n            \n    for cx in range(50, 78):\n        for cy in range(50, 78):\n            if (cx - 64)**2 + (cy - 64)**2 < 120: py16.mset(cx, cy, 4, layer=2)\n                \n    py16.mset(64, 60, 6, layer=2) \n    for _ in range(30): ow_clouds.append({\"x\": random.randint(0, 1024), \"y\": random.randint(10, 80), \"r\": random.randint(3, 8)})\n\ndef unlock_level_2():\n    for cy in range(61, 105):\n        py16.mset(63, cy, 7, layer=2); py16.mset(64, cy, 7, layer=2); py16.mset(65, cy, 7, layer=2)\n    py16.mset(64, 105, 8, layer=2) \n    play_tone(800, 200, py16.WAVE_SQUARE) \n\ndef unlock_level_3():\n    for cx in range(65, 96):\n        py16.mset(cx, 104, 7, layer=2); py16.mset(cx, 105, 7, layer=2); py16.mset(cx, 106, 7, layer=2)\n    for cx in range(86, 106):\n        for cy in range(95, 115):\n            if (cx - 96)**2 + (cy - 105)**2 < 80: py16.mset(cx, cy, 4, layer=2) \n    for cx in range(92, 102):\n        for cy in range(98, 104):\n            if random.random() > 0.4: py16.mset(cx, cy, 11, layer=2) \n    py16.mset(96, 105, 12, layer=2) \n    play_tone(800, 200, py16.WAVE_SQUARE)\n\ndef unlock_level_4():\n    for cy in range(55, 105):\n        py16.mset(95, cy, 7, layer=2); py16.mset(96, cy, 7, layer=2); py16.mset(97, cy, 7, layer=2)\n    for cx in range(86, 106):\n        for cy in range(45, 65):\n            if (cx - 96)**2 + (cy - 55)**2 < 80: py16.mset(cx, cy, 16, layer=2) \n    py16.mset(96, 55, 17, layer=2) \n    play_tone(800, 200, py16.WAVE_SQUARE)\n\ndef build_level_1():\n    py16.mclear(layer=1) \n    global goal_x, goal_y, bg_objects\n    goal_x, goal_y = get_level_width_pixels() - 40, 80 \n    for cx in range(0, LEVEL_WIDTH_TILES):\n        if (40 <= cx <= 45) or (80 <= cx <= 85): continue\n        ground_y = 14\n        if cx > 90: ground_y = 12\n        py16.mset(cx, ground_y, 1, layer=1); py16.mset(cx, ground_y + 1, 2, layer=1); py16.mset(cx, ground_y + 2, 2, layer=1)\n    for cx in range(10, 15): py16.mset(cx, 10, 1, layer=1) \n    for cx in range(20, 24): py16.mset(cx, 7, 1, layer=1) \n    for cy in range(12, 14): py16.mset(28, cy, 2, layer=1) \n    py16.mset(28, 11, 1, layer=1) \n    for cx in range(41, 44): py16.mset(cx, 10, 1, layer=1) \n    for cx in range(81, 84): py16.mset(cx, 9, 1, layer=1) \n    for cx in range(95, 100): py16.mset(cx, 8, 1, layer=1) \n    for cx in range(105, 110): py16.mset(cx, 6, 1, layer=1) \n    for cy in range(10, 12): py16.mset(122, cy, 2, layer=1) \n    py16.mset(122, 10, 1, layer=1) \n    for cx in range(50, 54): py16.mset(cx, 14, 3, layer=1) \n    for cx in range(35, 38): py16.mset(cx, 14, 3, layer=1) \n    for cx in range(70, 75): py16.mset(cx, 14, 3, layer=1) \n    bg_objects.clear()\n    for _ in range(25): bg_objects.append({\"type\": \"cloud\", \"x\": random.randint(0, get_level_width_pixels()), \"y\": random.randint(10, 60), \"r\": random.randint(5, 10)})\n\ndef build_level_2():\n    py16.mclear(layer=1) \n    global goal_x, goal_y, bg_objects\n    goal_x, goal_y = get_level_width_pixels() - 60, 48 \n    for cx in range(0, LEVEL_WIDTH_TILES):\n        if cx % 16 > 10: continue \n        py16.mset(cx, 14, 9, layer=1); py16.mset(cx, 15, 10, layer=1); py16.mset(cx, 16, 10, layer=1) \n    for cx in range(12, LEVEL_WIDTH_TILES - 10, 16):\n        py16.mset(cx, 11, 9, layer=1); py16.mset(cx+1, 11, 9, layer=1); py16.mset(cx+2, 11, 9, layer=1)\n        if cx + 8 < LEVEL_WIDTH_TILES - 10: py16.mset(cx+6, 8, 9, layer=1); py16.mset(cx+7, 8, 9, layer=1)\n    for cx in range(LEVEL_WIDTH_TILES - 10, LEVEL_WIDTH_TILES - 4):\n        py16.mset(cx, 8, 9, layer=1)\n        for cy in range(9, 17): py16.mset(cx, cy, 10, layer=1)\n    bg_objects.clear()\n    for _ in range(35): bg_objects.append({\"type\": \"fish\", \"x\": random.randint(0, get_level_width_pixels()), \"y\": random.randint(20, 180), \"color\": random.choice([8, 9, 10, 14, 15]), \"speed\": random.uniform(0.3, 1.5)})\n\ndef build_level_3():\n    py16.mclear(layer=1) \n    global goal_x, goal_y, bg_objects\n    goal_x, goal_y = get_level_width_pixels() - 60, 40 \n    for cx in range(0, LEVEL_WIDTH_TILES):\n        if cx % 24 > 15: continue \n        py16.mset(cx, 14, 13, layer=1); py16.mset(cx, 15, 14, layer=1); py16.mset(cx, 16, 14, layer=1)\n    for cx in [32, 56, 80]:\n        for cy in range(8, 14): py16.mset(cx, cy, 14, layer=1)\n    for cx in range(LEVEL_WIDTH_TILES - 10, LEVEL_WIDTH_TILES - 4):\n        py16.mset(cx, 8, 13, layer=1)\n        for cy in range(9, 17): py16.mset(cx, cy, 14, layer=1)\n    bg_objects.clear()\n    for _ in range(30): bg_objects.append({\"type\": \"cloud\", \"x\": random.randint(0, get_level_width_pixels()), \"y\": random.randint(10, 50), \"r\": random.randint(5, 10)})\n\ndef build_level_4():\n    py16.mclear(layer=1) \n    global goal_x, goal_y, bg_objects\n    goal_x, goal_y = -100, -100 \n    for cx in range(2, 30):\n        py16.mset(cx, 14, 16, layer=1); py16.mset(cx, 15, 16, layer=1) \n    for cx in range(0, 32):\n        py16.mset(cx, 16, 15, layer=1); py16.mset(cx, 17, 15, layer=1) \n    for cy in range(0, 18):\n        py16.mset(0, cy, 16, layer=1); py16.mset(1, cy, 16, layer=1)\n        py16.mset(30, cy, 16, layer=1); py16.mset(31, cy, 16, layer=1)\n    bg_objects.clear()\n\ndef get_tile(pixel_x, pixel_y):\n    return py16.mget(int(pixel_x) // 8, int(pixel_y) // 8, layer=1) \n\ndef is_solid(pixel_x, pixel_y):\n    t = py16.mget(int(pixel_x) // 8, int(pixel_y) // 8, layer=1)\n    return t in [1, 2, 9, 10, 13, 14, 16]\n\ndef get_overworld_tile(pixel_x, pixel_y):\n    return py16.mget(int(pixel_x) // 8, int(pixel_y) // 8, layer=2) \n\ndef check_spike_collision(p_x, p_y):\n    check_y = p_y + 7 \n    for check_x in range(int(p_x) + 1, int(p_x) + 7): \n        if get_tile(check_x, check_y) == 3: return True\n    return False\n\ndef reset_game():\n    global px, py, vx, vy, goal_reached, facing_right, walk_timer\n    global GRAVITY, JUMP_FORCE, coins, enemies, projectiles, score\n    global earthquake_timer, is_earthquake, moving_platforms\n    global boss, boss_death_timer, ending_timer, floating_texts\n    global cam_x, cam_y\n    \n    px, py, vx, vy = 32, 64, 0.0, 0.0\n    cam_x, cam_y = px - py16.WIDTH // 2, py - py16.HEIGHT // 2 # Reset Camera\n    \n    goal_reached = False\n    facing_right = True\n    walk_timer = 0\n    score = 0\n    projectiles = [] \n    moving_platforms.clear() \n    floating_texts.clear()\n    py16.particles_clear() \n    boss = {}\n    boss_death_timer = 0\n    ending_timer = 0\n    earthquake_timer = 0\n    is_earthquake = False\n    \n    if current_level == 1:\n        GRAVITY = 0.2; JUMP_FORCE = -4.8\n        c_pos = [(90, 64), (170, 40), (280, 96), (420, 80), (650, 96), (850, 80)]\n        coins = [{\"x\": cx, \"y\": cy, \"collected\": False} for cx, cy in c_pos]\n        enemies = [\n            {\"x\": 100, \"y\": 96, \"dx\": 1.0, \"vy\": 0.0, \"alive\": True, \"type\": \"walker\"},\n            {\"x\": 250, \"y\": 96, \"dx\": -1.0, \"vy\": 0.0, \"alive\": True, \"type\": \"walker\"},\n            {\"x\": 480, \"y\": 96, \"dx\": 1.0, \"vy\": 0.0, \"alive\": True, \"type\": \"walker\"},\n            {\"x\": 750, \"y\": 80, \"dx\": -1.0, \"vy\": 0.0, \"alive\": True, \"type\": \"walker\"}, \n            {\"x\": 920, \"y\": 80, \"dx\": 1.0, \"vy\": 0.0, \"alive\": True, \"type\": \"walker\"}  \n        ]\n        \n    elif current_level == 2:\n        GRAVITY = 0.08; JUMP_FORCE = -3.0\n        c_pos = [(120, 60), (240, 50), (480, 60), (700, 40), (850, 80)]\n        coins = [{\"x\": cx, \"y\": cy, \"collected\": False} for cx, cy in c_pos]\n        enemies = [\n            {\"x\": 160, \"y\": 104, \"dx\": 0, \"vy\": 0.0, \"alive\": True, \"type\": \"shooter\", \"timer\": 0},\n            {\"x\": 320, \"y\": 104, \"dx\": 0, \"vy\": 0.0, \"alive\": True, \"type\": \"shooter\", \"timer\": 40},\n            {\"x\": 560, \"y\": 104, \"dx\": 0, \"vy\": 0.0, \"alive\": True, \"type\": \"shooter\", \"timer\": 80},\n            {\"x\": 720, \"y\": 104, \"dx\": 0, \"vy\": 0.0, \"alive\": True, \"type\": \"shooter\", \"timer\": 20}\n        ]\n        shark_positions = [(200, 50, -2.5), (400, 90, 2.5), (600, 60, -2.5), (750, 100, 2.5), (850, 40, -2.5)]\n        for sx, sy, sdx in shark_positions: enemies.append({\"x\": sx, \"y\": sy, \"dx\": sdx, \"vy\": 0.0, \"alive\": True, \"type\": \"shark\"})\n            \n    elif current_level == 3:\n        GRAVITY = 0.2; JUMP_FORCE = -4.8\n        c_pos = [(144, 40), (336, 40), (528, 40), (720, 40)]\n        coins = [{\"x\": cx, \"y\": cy, \"collected\": False} for cx, cy in c_pos]\n        enemies = [\n            {\"x\": 200, \"y\": 96, \"dx\": 1.0, \"vy\": 0.0, \"alive\": True, \"type\": \"walker\"},\n            {\"x\": 400, \"y\": 96, \"dx\": -1.0, \"vy\": 0.0, \"alive\": True, \"type\": \"walker\"},\n            {\"x\": 600, \"y\": 96, \"dx\": 1.0, \"vy\": 0.0, \"alive\": True, \"type\": \"walker\"},\n            {\"x\": 800, \"y\": 96, \"dx\": -1.0, \"vy\": 0.0, \"alive\": True, \"type\": \"walker\"}\n        ]\n        moving_platforms.extend([\n            {\"x\": 128, \"y\": 80, \"w\": 32, \"h\": 8, \"dx\": 1.0, \"min_x\": 128, \"max_x\": 160},\n            {\"x\": 320, \"y\": 72, \"w\": 32, \"h\": 8, \"dx\": -1.2, \"min_x\": 320, \"max_x\": 352},\n            {\"x\": 512, \"y\": 80, \"w\": 32, \"h\": 8, \"dx\": 1.5, \"min_x\": 512, \"max_x\": 544},\n            {\"x\": 704, \"y\": 72, \"w\": 32, \"h\": 8, \"dx\": -1.0, \"min_x\": 704, \"max_x\": 736}\n        ])\n        \n    elif current_level == 4:\n        GRAVITY = 0.2; JUMP_FORCE = -4.8\n        coins = []\n        enemies = []\n        boss = {\n            \"x\": 100, \"y\": 20, \"w\": 32, \"h\": 32,\n            \"hp\": 3, \"state\": \"hover\", \"timer\": 0, \"vx\": -1.5,\n            \"target_x\": 0, \"target_y\": 0, \"alive\": True\n        }\n\ndef draw_heart(hx, hy):\n    hx, hy = int(hx), int(hy)\n    heart_pixels = [(1,0),(2,0),(4,0),(5,0), (0,1),(1,1),(2,1),(3,1),(4,1),(5,1),(6,1), (1,2),(2,2),(3,2),(4,2),(5,2), (2,3),(3,3),(4,3), (3,4)]\n    for dx, dy in heart_pixels: py16.pset(hx - 3 + dx, hy + dy, 8) \n    py16.pset(hx - 2, hy + 1, 7)\n\ndef draw_fluffy_cloud(x, y, r, is_water=False):\n    x_int, y_int = int(x), int(y)\n    color = 13 if is_water else 7 \n    py16.circfill(x_int, y_int, r, color) \n    py16.circfill(x_int - int(r*0.8), y_int + int(r*0.3), int(r*0.7), color)\n    py16.circfill(x_int + int(r*0.8), y_int + int(r*0.3), int(r*0.7), color)\n    py16.circfill(x_int, y_int + int(r*0.4), int(r*0.8), color)\n\ndef draw_fish(x, y, color):\n    x_int, y_int = int(x), int(y)\n    py16.circfill(x_int, y_int, 3, color) \n    py16.circfill(x_int + 2, y_int, 2, color) \n    py16.rectfill(x_int + 4, y_int - 2, 2, 5, color) \n    py16.pset(x_int - 1, y_int - 1, 0) \n    py16.pset(x_int - 2, y_int - 1, 7)\n\ndef draw_shark(x, y, dx):\n    x_int, y_int = int(x), int(y)\n    color = 5 \n    py16.circfill(x_int + 4, y_int + 4, 4, color) \n    py16.rectfill(x_int + 3, y_int, 2, 2, color) \n    if dx > 0:\n        py16.rectfill(x_int - 2, y_int + 2, 4, 4, color); py16.pset(x_int + 6, y_int + 2, 7); py16.pset(x_int + 6, y_int + 3, 0) \n    else:\n        py16.rectfill(x_int + 6, y_int + 2, 4, 4, color); py16.pset(x_int + 2, y_int + 2, 7); py16.pset(x_int + 2, y_int + 3, 0) \n\ndef draw_boss():\n    if not boss or not boss.get(\"alive\", False) and boss_death_timer == 0: return\n    bx, by = int(boss[\"x\"]), int(boss[\"y\"])\n    \n    # Boss blinkt wei\u00df, wenn er Schaden nimmt (Juice!)\n    is_hit = False # F\u00fcr zuk\u00fcnftige Hit-Timer Erweiterung\n    main_col = 7 if is_hit else 8\n    sec_col = 7 if is_hit else 9\n    \n    py16.circfill(bx + 16, by + 16, 16, main_col) \n    py16.circfill(bx + 16, by + 16, 12, sec_col)  \n    eye_col = 10 if boss.get(\"state\") == \"swoop\" else 7\n    py16.circfill(bx + 8, by + 10, 3, eye_col); py16.circfill(bx + 24, by + 10, 3, eye_col)\n    py16.pset(bx + 8, by + 10, 0); py16.pset(bx + 24, by + 10, 0)\n    py16.rectfill(bx + 10, by + 22, 12, 4, 0)\n    if boss[\"alive\"]:\n        py16.rectfill(10, 10, 60, 6, 0); py16.rectfill(10, 10, boss[\"hp\"] * 20, 6, 8); py16.text(\"BOSS HP\", 12, 11, 7)\n\ndef draw_tux(x, y, is_facing_right, timer):\n    x_int, y_int = int(x), int(y)\n    \n    # Wenn tot, zeichne ihn etwas verdunkelt/kopf\u00fcber\n    if game_state == \"DYING\":\n        py16.rectfill(x_int + 1, y_int + 1, 6, 6, 0)\n        py16.rectfill(x_int + 2, y_int + 4, 4, 3, 7)\n        py16.pset(x_int + 2, y_int + 6, 0)\n        return\n        \n    py16.rectfill(x_int + 1, y_int + 1, 6, 6, 0) \n    py16.rectfill(x_int + 2, y_int, 4, 1, 0)\n    anim_offset = (timer // 6) % 2 if timer > 0 else 0\n\n    if is_facing_right:\n        py16.rectfill(x_int + 4, y_int + 4, 3, 3, 7); py16.rectfill(x_int + 4, y_int + 2, 2, 1, 7); py16.pset(x_int + 5, y_int + 2, 0)\n        py16.rectfill(x_int + 6, y_int + 3, 2, 1, 10); py16.rectfill(x_int + 2 + anim_offset, y_int + 7, 2, 1, 10); py16.rectfill(x_int + 5 - anim_offset, y_int + 7, 2, 1, 10)\n    else:\n        py16.rectfill(x_int + 1, y_int + 4, 3, 3, 7); py16.rectfill(x_int + 2, y_int + 2, 2, 1, 7); py16.pset(x_int + 2, y_int + 2, 0)\n        py16.rectfill(x_int + 0, y_int + 3, 2, 1, 10); py16.rectfill(x_int + 4 - anim_offset, y_int + 7, 2, 1, 10); py16.rectfill(x_int + 1 + anim_offset, y_int + 7, 2, 1, 10)\n\ndef draw_title_bg():\n    py16.cls(12) \n    py16.circfill(200, 50, 24, 9)  \n    py16.circfill(200, 50, 20, 10) \n    bg_offset = py16.t() * 0.2 \n    for cloud in ow_clouds:\n        cx = (cloud[\"x\"] - bg_offset) % 1024 \n        if cx < py16.WIDTH + 20: draw_fluffy_cloud(cx, cloud[\"y\"], cloud[\"r\"])\n    py16.circfill(64, 250, 120, 3)  \n    py16.circfill(200, 240, 100, 11) \n\ndef update():\n    global px, py, vx, vy, on_ground, goal_reached\n    global facing_right, walk_timer, score, game_state, menu_index, high_score, sound_on\n    global ow_x, ow_y, ow_angle, level1_completed, level2_completed, level3_completed, current_level, projectiles\n    global earthquake_timer, is_earthquake, boss, boss_death_timer, ending_timer, lang\n    global cam_x, cam_y, floating_texts\n    \n    if game_state == \"MENU\":\n        if py16.btnp('up'): menu_index = (menu_index - 1) % 4 \n        if py16.btnp('down'): menu_index = (menu_index + 1) % 4 \n        if py16.btnp('enter') or py16.btnp('z'):\n            if menu_index == 0: game_state = \"OVERWORLD\" \n            elif menu_index == 1: game_state = \"HIGHSCORE\"\n            elif menu_index == 2: sound_on = not sound_on; play_tone(800, 50, py16.WAVE_SQUARE)\n            elif menu_index == 3: lang = \"EN\" if lang == \"DE\" else \"DE\"; play_tone(800, 50, py16.WAVE_SQUARE)\n        return\n\n    if game_state == \"HIGHSCORE\":\n        if py16.btnp('enter') or py16.btnp('z') or py16.btnp('x'): game_state = \"MENU\"\n        return\n\n    if game_state == \"OVERWORLD\":\n        if py16.btn('left'): ow_angle -= 0.05 \n        if py16.btn('right'): ow_angle += 0.05 \n        move = 0.0\n        if py16.btn('up'): move = ow_speed\n        if py16.btn('down'): move = -ow_speed\n        \n        next_ox = ow_x + py16.cos(ow_angle) * move \n        next_oy = ow_y + py16.sin(ow_angle) * move \n        if get_overworld_tile(next_ox, next_oy) != 5: ow_x, ow_y = next_ox, next_oy\n            \n        ow_tile = get_overworld_tile(ow_x, ow_y)\n        if py16.btnp('z') or py16.btnp('enter'):\n            if ow_tile == 6: current_level = 1; build_level_1(); reset_game(); game_state = \"PLAYING\"\n            elif ow_tile == 8: current_level = 2; build_level_2(); reset_game(); game_state = \"PLAYING\"\n            elif ow_tile == 12: current_level = 3; build_level_3(); reset_game(); game_state = \"PLAYING\"\n            elif ow_tile == 17: current_level = 4; build_level_4(); reset_game(); game_state = \"PLAYING\"\n                \n        if py16.btnp('x'): game_state = \"MENU\"\n        return\n\n    if game_state == \"PAUSED\":\n        if py16.btnp('x'): game_state = \"PLAYING\"\n        if py16.btnp('enter'): game_state = \"OVERWORLD\"\n        return\n\n    if game_state == \"ENDING\":\n        ending_timer += 1\n        if py16.btnp('enter') and ending_timer > 300:\n            game_state = \"OVERWORLD\"\n        return\n\n    if goal_reached:\n        if py16.btnp('enter'): \n            if score > high_score: high_score = score\n            if current_level == 1 and not level1_completed: level1_completed = True; unlock_level_2()\n            elif current_level == 2 and not level2_completed: level2_completed = True; unlock_level_3()\n            elif current_level == 3 and not level3_completed: level3_completed = True; unlock_level_4()\n            game_state = \"OVERWORLD\" \n        return \n        \n    # --- Todes-Animation Logik ---\n    if game_state == \"DYING\":\n        vy += GRAVITY\n        py += vy\n        if py > 200: # Aus dem Bildschirm gefallen\n            game_state = \"OVERWORLD\"\n        return\n        \n    if py16.btnp('x'):\n        game_state = \"PAUSED\"\n        return\n        \n    if current_level == 4 and boss:\n        if boss[\"alive\"]:\n            boss[\"timer\"] += 1\n            if boss[\"state\"] == \"hover\":\n                boss[\"x\"] += boss[\"vx\"]\n                if boss[\"x\"] < 20 or boss[\"x\"] > py16.WIDTH - 52: boss[\"vx\"] = -boss[\"vx\"]\n                if boss[\"timer\"] % 90 == 0:\n                    projectiles.append({\"x\": boss[\"x\"] + 16, \"y\": boss[\"y\"] + 32, \"dx\": 0, \"dy\": 2.5, \"type\": \"boss_fire\"})\n                    play_tone(150, 100, py16.WAVE_NOISE, channel=5)\n                if boss[\"timer\"] > 300:\n                    boss[\"state\"] = \"swoop\"; boss[\"timer\"] = 0; boss[\"target_x\"] = px - 12; boss[\"target_y\"] = 80 \n            elif boss[\"state\"] == \"swoop\":\n                dx = (boss[\"target_x\"] - boss[\"x\"]) * 0.05\n                dy = (boss[\"target_y\"] - boss[\"y\"]) * 0.05\n                boss[\"x\"] += dx; boss[\"y\"] += dy\n                if abs(boss[\"y\"] - boss[\"target_y\"]) < 2:\n                    boss[\"state\"] = \"swoop_wait\"; boss[\"timer\"] = 0; py16.scanline_jitter(amplitude=4); play_tone(80, 200, py16.WAVE_NOISE, channel=6)\n            elif boss[\"state\"] == \"swoop_wait\":\n                if boss[\"timer\"] > 60: boss[\"state\"] = \"swoop_up\"\n            elif boss[\"state\"] == \"swoop_up\":\n                boss[\"y\"] -= 2\n                if boss[\"y\"] <= 20: boss[\"state\"] = \"hover\"; boss[\"timer\"] = 0\n                    \n            if vy > 0 and py + 8 < boss[\"y\"] + 10 and px + 8 > boss[\"x\"] and px < boss[\"x\"] + boss[\"w\"]:\n                vy = JUMP_FORCE; boss[\"hp\"] -= 1; score += 100; py16.burst_explosion(px, py, color=10); play_tone(800, 100, py16.WAVE_TRIANGLE)\n                spawn_float_text(boss[\"x\"], boss[\"y\"], \"+100\") \n                if boss[\"hp\"] <= 0:\n                    boss[\"alive\"] = False; boss_death_timer = 1 \n            elif px + 6 > boss[\"x\"] + 4 and px + 2 < boss[\"x\"] + boss[\"w\"] - 4 and py + 6 > boss[\"y\"] + 4 and py + 2 < boss[\"y\"] + boss[\"h\"] - 4:\n                kill_player() \n        else:\n            boss_death_timer += 1\n            if boss_death_timer % 5 == 0:\n                py16.burst_explosion(boss[\"x\"] + random.randint(0, 32), boss[\"y\"] + random.randint(0, 32), color=8)\n                play_tone(random.randint(100, 200), 50, py16.WAVE_NOISE)\n            if boss_death_timer > 120:\n                game_state = \"ENDING\"; ending_timer = 0; score += 1000\n                if score > high_score: high_score = score\n                boss = {} \n        \n    if current_level == 3 and game_state == \"PLAYING\":\n        earthquake_timer += 1\n        if not is_earthquake and earthquake_timer > 180: \n            is_earthquake = True; earthquake_timer = 0; play_tone(80, 100, py16.WAVE_NOISE, channel=6) \n        elif is_earthquake:\n            if py16.t() % 12 == 0:\n                enemies.append({\"x\": px + random.randint(-60, 60), \"y\": py - 120, \"dx\": 0, \"vy\": 0, \"alive\": True, \"type\": \"falling_rock\"})\n            if earthquake_timer > 60: is_earthquake = False; earthquake_timer = 0\n        \n    if py16.t() % 8 == 0: \n        melody = boss_melody if current_level == 4 else bgm_melody\n        note_idx = (py16.t() // 8) % len(melody) \n        wave_type = py16.WAVE_TRIANGLE if current_level in [2, 4] else py16.WAVE_SQUARE \n        play_tone(melody[note_idx], 100, wave_type, channel=4)\n\n    if not (current_level == 4 and not boss.get(\"alive\", True)):\n        vx = 0\n        if py16.btn('left'): vx = -SPEED; facing_right = False \n        if py16.btn('right'): vx = SPEED; facing_right = True \n\n        for p in moving_platforms:\n            p[\"x\"] += p[\"dx\"]\n            if p[\"x\"] < p[\"min_x\"] or p[\"x\"] > p[\"max_x\"]: p[\"dx\"] = -p[\"dx\"] \n                \n        standing_plat = None\n        for p in moving_platforms:\n            if px + 7 >= p[\"x\"] and px <= p[\"x\"] + p[\"w\"]:\n                if abs((py + 8) - p[\"y\"]) <= 1 and vy >= 0:\n                    standing_plat = p; break\n\n        if standing_plat: vx += standing_plat[\"dx\"] \n\n        if vx != 0 and on_ground: walk_timer += 1\n        else: walk_timer = 0 \n        \n        if py16.btnp('z') and on_ground: \n            vy = JUMP_FORCE\n            color = 12 if current_level == 2 else 7 \n            py16.burst_smoke(px + 4, py + 8, color=color); play_tone(300, 100, py16.WAVE_SQUARE) \n    \n    if current_level == 2 and vy > 1.5: vy = 1.5 \n    else: vy += GRAVITY\n        \n    next_x, next_y = px + vx, py + vy\n    \n    # Speichere alten Zustand f\u00fcr Lande-Partikel\n    was_on_ground = on_ground\n    on_ground = False\n    \n    if vx > 0:\n        if is_solid(next_x + 7, py + 1) or is_solid(next_x + 7, py + 7): next_x = (int(next_x + 7) // 8) * 8 - 8\n    elif vx < 0:\n        if is_solid(next_x, py + 1) or is_solid(next_x, py + 7): next_x = (int(next_x) // 8) * 8 + 8\n        \n    if vy > 0:\n        if is_solid(next_x + 1, next_y + 8) or is_solid(next_x + 6, next_y + 8):\n            if (py + 8) <= (int(next_y + 8) // 8) * 8: next_y = (int(next_y + 8) // 8) * 8 - 8; vy = 0; on_ground = True\n    elif vy < 0:\n        if is_solid(next_x + 1, next_y) or is_solid(next_x + 6, next_y): next_y = (int(next_y) // 8) * 8 + 8; vy = 0\n            \n    if vy > 0 and not on_ground:\n        for p in moving_platforms:\n            if next_x + 7 >= p[\"x\"] and next_x <= p[\"x\"] + p[\"w\"]:\n                if py + 8 <= p[\"y\"] and next_y + 8 >= p[\"y\"]:\n                    next_y = p[\"y\"] - 8; vy = 0; on_ground = True; break\n                    \n    px, py = next_x, next_y\n    \n    if on_ground and not was_on_ground and vy >= 0:\n        py16.burst_smoke(px+4, py+8, color=6)\n    \n    if check_spike_collision(px, py):\n        kill_player() \n        \n    if py > 120 and current_level == 4:\n        kill_player() \n    \n    for c in coins:\n        if not c[\"collected\"] and px < c[\"x\"] + 8 and px + 8 > c[\"x\"] and py < c[\"y\"] + 8 and py + 8 > c[\"y\"]:\n            c[\"collected\"] = True; score += 10; play_tone(1200, 50, py16.WAVE_SQUARE); py16.burst_sparks(c[\"x\"] + 4, c[\"y\"] + 4, color=10) \n            spawn_float_text(c[\"x\"], c[\"y\"] - 5, \"+10\", 10) \n    \n    if current_level != 4 and px < goal_x + 8 and px + 8 > goal_x and py < goal_y + 16 and py + 8 > goal_y:\n        goal_reached = True; py16.burst_confetti(goal_x + 4, goal_y, count=40); play_tone(600, 150, py16.WAVE_SQUARE); play_tone(800, 200, py16.WAVE_SQUARE) \n    \n    for e in enemies:\n        if not e[\"alive\"]: continue\n        if e[\"type\"] == \"falling_rock\":\n            e[\"vy\"] += GRAVITY * 1.5 \n            next_ey = e[\"y\"] + e[\"vy\"]\n            if is_solid(e[\"x\"] + 1, next_ey + 8) or is_solid(e[\"x\"] + 6, next_ey + 8):\n                e[\"alive\"] = False; py16.burst_smoke(e[\"x\"] + 4, e[\"y\"] + 8, color=6); play_tone(120, 50, py16.WAVE_NOISE, channel=5)\n            e[\"y\"] = next_ey\n        elif e[\"type\"] in [\"walker\", \"shooter\"]:\n            e[\"vy\"] += GRAVITY\n            next_ey = e[\"y\"] + e[\"vy\"]\n            if is_solid(e[\"x\"] + 1, next_ey + 8) or is_solid(e[\"x\"] + 6, next_ey + 8):\n                next_ey = (int(next_ey + 8) // 8) * 8 - 8; e[\"vy\"] = 0 \n            e[\"y\"] = next_ey\n        if e[\"type\"] == \"walker\":\n            e[\"x\"] += e[\"dx\"]\n            edge_x = e[\"x\"] + 8 if e[\"dx\"] > 0 else e[\"x\"] - 1\n            if not is_solid(edge_x, e[\"y\"] + 8) or is_solid(edge_x, e[\"y\"] + 4): e[\"dx\"] = -e[\"dx\"]\n        elif e[\"type\"] == \"shark\":\n            e[\"x\"] += e[\"dx\"]\n            front_x = e[\"x\"] + 8 if e[\"dx\"] > 0 else e[\"x\"] - 1\n            if is_solid(front_x, e[\"y\"] + 4): e[\"dx\"] = -e[\"dx\"] \n        elif e[\"type\"] == \"shooter\":\n            e[\"timer\"] += 1\n            if e[\"timer\"] > 120: \n                e[\"timer\"] = 0; angle = py16.atan2(py - e[\"y\"], px - e[\"x\"])\n                projectiles.append({\"x\": e[\"x\"] + 4, \"y\": e[\"y\"] + 4, \"dx\": py16.cos(angle) * 1.5, \"dy\": py16.sin(angle) * 1.5, \"type\": \"spike\"})\n                play_tone(400, 50, py16.WAVE_NOISE, channel=5) \n        \n        if px < e[\"x\"] + 8 and px + 8 > e[\"x\"] and py < e[\"y\"] + 8 and py + 8 > e[\"y\"]:\n            if e[\"type\"] == \"falling_rock\":\n                kill_player() \n            elif vy > 0 and py < e[\"y\"] and e[\"type\"] != \"shark\":\n                e[\"alive\"] = False; vy = JUMP_FORCE * 0.8; score += 50\n                py16.burst_sparks(e[\"x\"] + 4, e[\"y\"] + 4, color=10); play_tone(600, 80, py16.WAVE_TRIANGLE) \n                spawn_float_text(e[\"x\"], e[\"y\"], \"+50\", 11) \n            else:\n                kill_player() \n                \n    alive_projectiles = []\n    for p in projectiles:\n        p[\"x\"] += p[\"dx\"]; p[\"y\"] += p[\"dy\"]\n        \n        if px < p[\"x\"] + 2 and px + 8 > p[\"x\"] - 2 and py < p[\"y\"] + 2 and py + 8 > p[\"y\"] - 2:\n            kill_player() \n            continue \n            \n        if p.get(\"type\") == \"boss_fire\" and is_solid(p[\"x\"], p[\"y\"]):\n            tx, ty = int(p[\"x\"]) // 8, int(p[\"y\"]) // 8\n            py16.mset(tx, ty, 0, layer=1) \n            py16.mset(tx, ty+1, 0, layer=1) \n            py16.burst_smoke(p[\"x\"], p[\"y\"], color=8); play_tone(100, 100, py16.WAVE_NOISE)\n            continue\n            \n        elif is_solid(p[\"x\"], p[\"y\"]):\n            py16.burst_sparks(p[\"x\"], p[\"y\"], color=8) \n            continue\n            \n        alive_projectiles.append(p)\n    projectiles = alive_projectiles \n    \n    for ft in floating_texts[:]:\n        ft[\"y\"] -= 0.5\n        ft[\"timer\"] -= 1\n        if ft[\"timer\"] <= 0:\n            floating_texts.remove(ft)\n    \n    if py > 200 and game_state != \"DYING\": game_state = \"OVERWORLD\"\n\ndef draw():\n    t_start = T[lang][\"start\"]\n    t_high = T[lang][\"highscore\"]\n    t_snd = T[lang][\"sound_on\"] if sound_on else T[lang][\"sound_off\"]\n    t_lang = T[lang][\"lang\"]\n\n    if game_state == \"MENU\":\n        draw_title_bg()\n        py16.rectfill(50, 20, 156, 30, 0); py16.rect(50, 20, 156, 30, 7); py16.text(\"TUX ADVENTURE\", 80, 32, 10) \n        \n        c0 = 10 if menu_index == 0 else 7; c1 = 10 if menu_index == 1 else 7\n        c2 = 10 if menu_index == 2 else 7; c3 = 10 if menu_index == 3 else 7\n        \n        py16.text(t_start, 100, 95, c0)\n        py16.text(t_high, 100, 110, c1) \n        py16.text(t_snd, 100, 125, c2) \n        py16.text(t_lang, 100, 140, c3) \n        py16.text(\">\", 90, 95 + menu_index * 15, 10) \n        return\n\n    if game_state == \"HIGHSCORE\":\n        draw_title_bg()\n        py16.rectfill(40, 50, 176, 100, 0); py16.rect(40, 50, 176, 100, 7) \n        py16.text(T[lang][\"best_scores\"], 80, 60, 7)\n        py16.text(f\"{T[lang]['record']} {high_score}\", 90, 90, 10) \n        py16.text(T[lang][\"press_enter\"], 85, 120, 6)\n        py16.text(T[lang][\"for_back\"], 90, 130, 6) \n        return\n\n    if game_state == \"OVERWORLD\":\n        py16.cls(12) \n        py16.mode7(ow_x, ow_y, ow_angle, horizon_y=80, sky_color=12, layer=2) \n        \n        is_moving = py16.btn('up') or py16.btn('down')\n        ow_walk_timer = py16.t() if is_moving else 0\n        draw_tux(py16.WIDTH // 2 - 4, py16.HEIGHT - 40, True, ow_walk_timer)\n        \n        py16.camera(0, 0)\n        ow_tile = get_overworld_tile(ow_x, ow_y)\n        if ow_tile == 6: py16.rectfill(30, 20, 196, 20, 0); py16.rect(30, 20, 196, 20, 7); py16.text(T[lang][\"level1\"], 38, 26, 10)\n        elif ow_tile == 8: py16.rectfill(30, 20, 196, 20, 0); py16.rect(30, 20, 196, 20, 12); py16.text(T[lang][\"level2\"], 42, 26, 11)\n        elif ow_tile == 12: py16.rectfill(30, 20, 196, 20, 0); py16.rect(30, 20, 196, 20, 10); py16.text(T[lang][\"level3\"], 38, 26, 10)\n        elif ow_tile == 17: py16.rectfill(30, 20, 196, 20, 0); py16.rect(30, 20, 196, 20, 8); py16.text(T[lang][\"level4\"], 42, 26, 8)\n        else: py16.rectfill(0, 0, py16.WIDTH, 12, 0); py16.text(T[lang][\"map_move\"], 4, 4, 7)\n            \n        py16.text(T[lang][\"back\"], 4, py16.HEIGHT - 10, 6)\n        return\n\n    if game_state == \"ENDING\":\n        py16.cls(2) \n        py16.camera(0, 0)\n        for cx in range(32):\n            py16.mset(cx, 14, 16, layer=1); py16.mset(cx, 15, 16, layer=1)\n        py16.draw_map(0, 0, 0, 0, 32, 32, layer=1)\n        \n        tux_x = 80; penny_x = 160; t_y = 104 \n        \n        draw_tux(tux_x, t_y, True, 0) \n        draw_tux(penny_x, t_y, False, 0) \n        \n        py16.rectfill(penny_x + 3, t_y - 2, 4, 3, 8); py16.pset(penny_x + 4, t_y - 1, 7); py16.pset(penny_x + 5, t_y - 1, 8)\n        \n        if ending_timer > 60:\n            py16.text(T[lang][\"thanks1\"], 60, 40, 7)\n            py16.text(T[lang][\"thanks2\"], 75, 50, 7)\n            \n        if ending_timer > 120:\n            heart_prog = min(1.0, (ending_timer - 120) / 100.0)\n            hx = penny_x - 10 - (penny_x - tux_x - 20) * heart_prog\n            hy = t_y - 10 + py16.sin(ending_timer * 0.1) * 5\n            draw_heart(hx, hy)\n            \n        if ending_timer > 300:\n            py16.rectfill(50, 110, 156, 20, 0); py16.rect(50, 110, 156, 20, 7)\n            py16.text(T[lang][\"enter_map\"], 75, 116, 10)\n        return\n\n    bg_color = 2 if current_level == 4 else (1 if current_level == 2 else 12) \n    py16.cls(bg_color) \n    \n    global cam_x, cam_y\n    if current_level == 4:\n        cam_x = 0\n    else:\n        target_cam_x = py16.mid(0, px - (py16.WIDTH // 2), get_level_width_pixels() - py16.WIDTH)\n        cam_x += (target_cam_x - cam_x) * 0.1 \n        \n    cam_y = py16.mid(0, py - (py16.HEIGHT // 2) + 20, 60) \n    \n    time_val = 0 if game_state == \"PAUSED\" else py16.t()\n    \n    if current_level == 3 and is_earthquake and game_state != \"PAUSED\": py16.scanline_jitter(amplitude=4) \n    \n    parallax_offset_x = (cam_x * 0.4) + (time_val * 0.1) \n    for obj in bg_objects:\n        if obj[\"type\"] == \"cloud\":\n            screen_cx = (obj[\"x\"] - parallax_offset_x) % get_level_width_pixels()\n            if cam_x <= screen_cx <= cam_x + py16.WIDTH or cam_x <= screen_cx + 20 <= cam_x + py16.WIDTH:\n                 py16.camera(cam_x, cam_y * 0.5); draw_fluffy_cloud(screen_cx, obj[\"y\"], obj[\"r\"], is_water=(current_level == 2)) \n        elif obj[\"type\"] == \"fish\":\n            fish_parallax = cam_x * 0.3\n            screen_cx = (obj[\"x\"] - fish_parallax - time_val * obj[\"speed\"]) % get_level_width_pixels()\n            if cam_x <= screen_cx <= cam_x + py16.WIDTH or cam_x <= screen_cx + 20 <= cam_x + py16.WIDTH:\n                 py16.camera(cam_x, cam_y * 0.5); draw_fish(screen_cx, obj[\"y\"], obj[\"color\"])\n    \n    py16.camera(cam_x, cam_y) \n    \n    py16.draw_map(0, 0, 0, 0, get_level_width_pixels() // 8, LEVEL_HEIGHT_TILES, layer=1) \n    \n    if current_level == 4: draw_boss()\n    \n    for c in coins:\n        if not c[\"collected\"]: py16.circfill(c[\"x\"] + 4, c[\"y\"] + 4, 3, 10); py16.rectfill(c[\"x\"] + 3, c[\"y\"] + 2, 2, 4, 7) \n    if current_level != 4:\n        py16.rectfill(goal_x, goal_y, 2, 16, 6); py16.rectfill(goal_x + 2, goal_y, 8, 6, 10) \n    \n    for p in moving_platforms:\n        px_int, py_int = int(p[\"x\"]), int(p[\"y\"]); py16.rectfill(px_int, py_int, p[\"w\"], p[\"h\"], 14); py16.rectfill(px_int, py_int, p[\"w\"], 2, 13)      \n    \n    for e in enemies:\n        if not e[\"alive\"]: continue\n        ex, ey = int(e[\"x\"]), int(e[\"y\"])\n        if e[\"type\"] == \"walker\": py16.rectfill(ex, ey, 8, 8, 9); py16.pset(ex + 2, ey + 2, 0); py16.pset(ex + 5, ey + 2, 0) \n        elif e[\"type\"] == \"shooter\":\n            py16.circfill(ex + 4, ey + 4, 4, 13); py16.pset(ex + 2, ey + 3, 7); py16.pset(ex + 5, ey + 3, 7) \n            py16.line(ex+4, ey+4, ex+4, ey-1, 14); py16.line(ex+4, ey+4, ex-1, ey+4, 14); py16.line(ex+4, ey+4, ex+9, ey+4, 14); py16.line(ex+4, ey+4, ex+1, ey+1, 14); py16.line(ex+4, ey+4, ex+7, ey+1, 14)\n        elif e[\"type\"] == \"shark\": draw_shark(ex, ey, e[\"dx\"])\n        elif e[\"type\"] == \"falling_rock\": py16.circfill(ex + 4, ey + 4, 4, 5); py16.circfill(ex + 2, ey + 2, 2, 6) \n            \n    for p in projectiles:\n        col = 9 if p.get(\"type\") == \"boss_fire\" else 8\n        py16.circfill(int(p[\"x\"]), int(p[\"y\"]), 3 if col == 9 else 2, col) \n    \n    draw_tux(px, py, facing_right, walk_timer if game_state != \"PAUSED\" else 0)\n    \n    for ft in floating_texts:\n        py16.text(ft[\"text\"], int(ft[\"x\"]), int(ft[\"y\"]), ft[\"color\"])\n    \n    if game_state != \"PAUSED\": py16.particles_update()\n    py16.particles_draw() \n    \n    if current_level == 2:\n        wave = py16.scanline_wave(time_val, amplitude=2, frequency=0.05); py16.scanline_apply(wave, wrap=True) \n    \n    py16.camera(0, 0) \n    \n    if game_state == \"PAUSED\":\n        py16.blend_mode(\"alpha\", alpha=128); py16.rectfill(0, 0, py16.WIDTH, py16.HEIGHT, 0); py16.blend_mode(\"normal\")\n        py16.rectfill(90, 90, 76, 50, 0); py16.rect(90, 90, 76, 50, 7)\n        py16.text(T[lang][\"pause\"], 108, 100, 10)\n        py16.text(T[lang][\"resume\"], 95, 115, 7)\n        py16.text(T[lang][\"map_btn\"], 95, 125, 7)\n    elif goal_reached:\n        py16.rectfill(30, 90, 196, 50, 0); py16.rect(30, 90, 196, 50, 7) \n        if current_level == 4:\n            py16.text(T[lang][\"game_clear1\"], 50, 98, 10)\n            py16.text(T[lang][\"game_clear2\"], 60, 110, 11)\n        else:\n            py16.text(T[lang][\"goal\"], 80, 98, 10)\n            py16.text(f\"{T[lang]['score']}{score}\", 76, 110, 11)\n        py16.text(T[lang][\"enter_map\"], 75, 125, 7) \n    elif game_state not in [\"ENDING\", \"DYING\"]:\n        py16.text(f\"{T[lang]['score']}{score}\", 4, 4, 10) \n\nif __name__ == \"__main__\":\n    py16.run(update, draw, init)\n", "code_file": "/home/dennis/.py16/carts/tux_adveture.py", "meta": {"title": "TUX ADVETURE", "author": "Gemini 3.1", "cover_style": "custom", "color_bg": 16, "color_band": 31, "color_title_text": 1, "color_author_text": 7, "font": "helvetica", "custom_image": "", "title_size": 32, "title_bold": true, "title_italic": false, "title_underline": false, "author_size": 10, "author_bold": true, "author_italic": false, "author_underline": false}}
